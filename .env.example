# Runtime home directory used by CLI and Docker overrides
# Windows
ENNOIA_HOME=C:\Users\Administrator\.ennoia
# macOS / Linux
# ENNOIA_HOME=/Users/your-name/.ennoia
# ENNOIA_HOME=/home/your-name/.ennoia

# Optional overrides for the packaged npm launcher
ENNOIA_CLI_PROFILE=debug
# Windows
# ENNOIA_CLI_BIN=D:\data\code\ennoia\target\debug\ennoia.exe
# macOS / Linux
# ENNOIA_CLI_BIN=/Users/your-name/code/ennoia/target/debug/ennoia
# ENNOIA_CLI_BIN=/home/your-name/code/ennoia/target/debug/ennoia

# Web frontend API endpoint
VITE_ENNOIA_API_URL=http://127.0.0.1:3710
