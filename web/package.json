{
  "name": "@ennoia/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../scripts/run-web-bin.mjs vite bin/vite.js",
    "panda:codegen": "node ../scripts/panda-codegen.mjs",
    "build": "node ../scripts/build-extension-ui.mjs && bun run panda:codegen && node ../scripts/run-web-bin.mjs vite bin/vite.js build",
    "lint": "bun run panda:codegen && node ../scripts/run-web-bin.mjs eslint bin/eslint.js src packages",
    "typecheck": "bun run panda:codegen && node ../scripts/run-web-bin.mjs typescript bin/tsc --noEmit",
    "test:smoke": "bun run build",
    "prepare": "bun run panda:codegen"
  },
  "dependencies": {
    "@ennoia/api-client": "workspace:*",
    "@ennoia/contract": "workspace:*",
    "@ennoia/i18n": "workspace:*",
    "@ennoia/observability": "workspace:*",
    "@ennoia/theme-runtime": "workspace:*",
    "@ennoia/ui-sdk": "workspace:*",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "^1.168.21",
    "dockview": "^5.2.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pandacss/dev": "^1.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.9",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.2.0"
  }
}
