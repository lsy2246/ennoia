{
  "name": "ennoia",
  "version": "0.1.0",
  "private": true,
  "description": "Ennoia source workspace",
  "type": "module",
  "workspaces": [
    "web",
    "web/packages/*"
  ],
  "scripts": {
    "install": "node ./scripts/install-workspace.mjs",
    "dev": "cargo run -p ennoia-cli -- dev",
    "build:extension-ui": "node ./scripts/build-extension-ui.mjs",
    "watch:extension-ui": "node ./scripts/build-extension-ui.mjs --watch",
    "build:workers": "node ./scripts/build-workers.mjs",
    "build:web": "npm run build:extension-ui && bun run --cwd web build",
    "check:web": "bun run --cwd web typecheck",
    "pack:npm": "node ./scripts/pack-npm.mjs",
    "docker:build": "docker compose build"
  }
}
